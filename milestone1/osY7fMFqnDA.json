[
  {
    "text": "వెన్న కరిగితే వేడికి నిదర్శనం మనసు",
    "start": 1.68,
    "duration": 9.455
  },
  {
    "text": "[సంగీతం] కరిగితే మానవతకు నిదర్శనం",
    "start": 6.55,
    "duration": 9.17
  },
  {
    "text": "[సంగీతం] మనిషి ఎప్పుడూ తనకున్న సంపదతో",
    "start": 11.135,
    "duration": 8.705
  },
  {
    "text": "[సంగీతం] తృప్తి పడాలి. కానీ తనకున్న",
    "start": 15.72,
    "duration": 7.719
  },
  {
    "text": "విజ్ఞానంతో తృప్తి పడకూడదు.",
    "start": 19.84,
    "duration": 9.04
  },
  {
    "text": "మనిషికి తప్పప్పుల విచక్షణ అవసరం",
    "start": 23.439,
    "duration": 8.321
  },
  {
    "text": "తెలిసి తప్పు చేయకూడదు.",
    "start": 28.88,
    "duration": 5.359
  },
  {
    "text": "ధనం సంపాదించేందుకు",
    "start": 31.76,
    "duration": 7.28
  },
  {
    "text": "మనుషులు అవినీతికి పాల్పడతారు. సుఖం కోసం",
    "start": 34.239,
    "duration": 6.401
  },
  {
    "text": "అనైతికంగా",
    "start": 39.04,
    "duration": 3.519
  },
  {
    "text": "ప్రవర్తిస్తుంటారు.",
    "start": 40.64,
    "duration": 6.64
  },
  {
    "text": "తప్పని తెలిసి చేయకూడని పనులు చేస్తే",
    "start": 42.559,
    "duration": 10.16
  },
  {
    "text": "ఫలితాలు వ్యతిరేకంగానే ఉంటాయి. ఏది తప్పో",
    "start": 47.28,
    "duration": 8.959
  },
  {
    "text": "ఏది మంచో గ్రహించగలగడం",
    "start": 52.719,
    "duration": 6.0
  },
  {
    "text": "ఒక సాధన.",
    "start": 56.239,
    "duration": 4.0
  },
  {
    "text": "మనోనిగ్రహం",
    "start": 58.719,
    "duration": 3.121
  },
  {
    "text": "కోల్పోతే",
    "start": 60.239,
    "duration": 4.88
  },
  {
    "text": "మనిషి తప్పులు చేస్తాడు.",
    "start": 61.84,
    "duration": 6.16
  },
  {
    "text": "దాని [సంగీతం] ఫలితాలు ఎంత దారుణంగా",
    "start": 65.119,
    "duration": 6.161
  },
  {
    "text": "ఉంటాయో ఆలోచించడు.",
    "start": 68.0,
    "duration": 8.159
  },
  {
    "text": "దొంగిలించడం తప్పు దుర్భర దారిద్రయాన్ని",
    "start": 71.28,
    "duration": 6.64
  },
  {
    "text": "అనుభవించలేక",
    "start": 76.159,
    "duration": 4.96
  },
  {
    "text": "దొంగతనం [సంగీతం] చేస్తారని సమర్ధించుకునే",
    "start": 77.92,
    "duration": 8.879
  },
  {
    "text": "ప్రయత్నం చేస్తారు. కానీ అది అసమర్ధుడికి",
    "start": 81.119,
    "duration": 7.521
  },
  {
    "text": "సమర్ధన.",
    "start": 86.799,
    "duration": 6.0
  },
  {
    "text": "తిని తినక అర్ధాకలితో [సంగీతం] ఉంటూ",
    "start": 88.64,
    "duration": 9.439
  },
  {
    "text": "జీవించే వాళ్ళు ఎందరో ఉన్నారు. కదా",
    "start": 92.799,
    "duration": 7.121
  },
  {
    "text": "మహాభారతంలో",
    "start": 98.079,
    "duration": 6.641
  },
  {
    "text": "కుచేలుడు ఎంతో దారిద్రయాన్ని అనుభవించి",
    "start": 99.92,
    "duration": 7.519
  },
  {
    "text": "చివరికి [సంగీతం] చిరనాటి మిత్రుని",
    "start": 104.72,
    "duration": 6.56
  },
  {
    "text": "ఆశ్రయించాడే గానీ తప్పు చేయలేదు.",
    "start": 107.439,
    "duration": 8.401
  },
  {
    "text": "త్వచ్ఛమైన సుఖాల కోసం సభ్య సమాజాన్ని",
    "start": 111.28,
    "duration": 7.839
  },
  {
    "text": "కలుషితం చేస్తున్న వారు దుష్ఫలితాలను",
    "start": 115.84,
    "duration": 7.04
  },
  {
    "text": "అనుభవిస్తూనే ఉన్నారు. ఏ తప్పు చేయని వారు",
    "start": 119.119,
    "duration": 8.0
  },
  {
    "text": "గౌరవంగా తలెత్తుకొని జీవిస్తున్నారు",
    "start": 122.88,
    "duration": 7.999
  },
  {
    "text": "జీవించాలి కూడా క్రమశిక్షణ",
    "start": 127.119,
    "duration": 8.801
  },
  {
    "text": "లోపించిన మనసు మన శత్రువుగా మారుతుంది.",
    "start": 130.879,
    "duration": 9.36
  },
  {
    "text": "సుశిక్షితమైన మనసు మన నేస్తంగా",
    "start": 135.92,
    "duration": 6.24
  },
  {
    "text": "వ్యవహరిస్తుంది. [సంగీతం]",
    "start": 140.239,
    "duration": 5.681
  },
  {
    "text": "తెలిసి తప్పులు చేయడానికి కారణం",
    "start": 142.16,
    "duration": 8.079
  },
  {
    "text": "క్రమశిక్షణ లేని మనసే మనకు [సంగీతం]",
    "start": 145.92,
    "duration": 6.0
  },
  {
    "text": "విధేయంగాను",
    "start": 150.239,
    "duration": 5.36
  },
  {
    "text": "మనతో సహకరించే విధంగాను",
    "start": 151.92,
    "duration": 7.52
  },
  {
    "text": "దాన్ని సుశిక్షితం చేసుకోవాలి. నేనే",
    "start": 155.599,
    "duration": 8.481
  },
  {
    "text": "తింటాను నేనే చూస్తాను నేనే మాట్లాడుతాను",
    "start": 159.44,
    "duration": 9.6
  },
  {
    "text": "నేనే వింటాను. అనే భౌతిక భావనల్లో",
    "start": 164.08,
    "duration": 8.0
  },
  {
    "text": "అహం వ్యక్తమవుతుంది.",
    "start": 169.04,
    "duration": 6.64
  },
  {
    "text": "దానివల్లే క్రమం తప్పిన జీవితం [సంగీతం]",
    "start": 172.08,
    "duration": 5.519
  },
  {
    "text": "అలవాటవుతుంది.",
    "start": 175.68,
    "duration": 7.279
  },
  {
    "text": "మనసే మన నడవడికను నిర్దేశిస్తుంది.",
    "start": 177.599,
    "duration": 7.681
  },
  {
    "text": "మనసు చెప్పు చేతల్లో [సంగీతం]",
    "start": 182.959,
    "duration": 5.92
  },
  {
    "text": "మానవ జీవితం ఉండకూడదన్నది",
    "start": 185.28,
    "duration": 5.76
  },
  {
    "text": "పెద్దల మాట.",
    "start": 188.879,
    "duration": 7.121
  },
  {
    "text": "మనసు తనకు ఇష్టమైన సంఘటనతో",
    "start": 191.04,
    "duration": 7.52
  },
  {
    "text": "ఆనందం పొందుతుంది.",
    "start": 196.0,
    "duration": 7.519
  },
  {
    "text": "ప్రతికూలమైన వాటితో దుఃఖపూరితమవుతుంది.",
    "start": 198.56,
    "duration": 7.599
  },
  {
    "text": "మనసును క్రమశిక్షణలో",
    "start": 203.519,
    "duration": 4.72
  },
  {
    "text": "ఉంచగలిగితేనే",
    "start": 206.159,
    "duration": 8.481
  },
  {
    "text": "అహంకారం తాలూకు నిజమైన మూలాలు తెలుస్తాయి.",
    "start": 208.239,
    "duration": 9.521
  },
  {
    "text": "మనసు బుద్ధి",
    "start": 214.64,
    "duration": 6.48
  },
  {
    "text": "చిత్తం అనగా ఆలోచన",
    "start": 217.76,
    "duration": 7.839
  },
  {
    "text": "అహంకారం అనే నాలుగు వికారాలే",
    "start": 221.12,
    "duration": 10.24
  },
  {
    "text": "మనిషి పతనానికి కారణం అని నిర్వాణ శట్కంలో",
    "start": 225.599,
    "duration": 9.601
  },
  {
    "text": "శంకర భగవత్పాదులు ప్రతిపాదించారు.",
    "start": 231.36,
    "duration": 7.439
  },
  {
    "text": "మానవ వ్యక్తిత్వాన్ని కఠోపనిషత్తు",
    "start": 235.2,
    "duration": 8.16
  },
  {
    "text": "చక్కగా వివరించింది. వ్యక్తిత్వం రథం",
    "start": 238.799,
    "duration": 8.08
  },
  {
    "text": "లాంటిది రథంలో ప్రయాణించేవాడు",
    "start": 243.36,
    "duration": 5.12
  },
  {
    "text": "అహంకారానికి",
    "start": 246.879,
    "duration": 4.481
  },
  {
    "text": "ప్రతీక రథసారధి",
    "start": 248.48,
    "duration": 7.68
  },
  {
    "text": "బుద్ధికి సంకేతం కళ్యాలు మనసును",
    "start": 251.36,
    "duration": 6.399
  },
  {
    "text": "సూచిస్తాయి.",
    "start": 256.16,
    "duration": 3.759
  },
  {
    "text": "గుర్రాలు జ్ఞానేంద్రియాలు [సంగీతం]",
    "start": 257.759,
    "duration": 6.72
  },
  {
    "text": "లాంటివి రథం ప్రయాణించే దారి విషయ",
    "start": 259.919,
    "duration": 10.0
  },
  {
    "text": "వస్తువులకు గుర్తు ఇలాంటి రథానికి పూంచిన",
    "start": 264.479,
    "duration": 10.961
  },
  {
    "text": "గుర్రాలు శిక్షణ పొందినవి కాకపోతే లేదా రథ",
    "start": 269.919,
    "duration": 9.521
  },
  {
    "text": "సారధి నిద్రలోకి జారిపోతే",
    "start": 275.44,
    "duration": 8.319
  },
  {
    "text": "రథం గమ్యాన్ని చేరుకోలేదు.",
    "start": 279.44,
    "duration": 10.0
  },
  {
    "text": "రథం బోల్తాపడి యజమాని మరణానికి కూడా దారి",
    "start": 283.759,
    "duration": 8.429
  },
  {
    "text": "తీయవచ్చు [సంగీతం]",
    "start": 289.44,
    "duration": 2.748
  }
]